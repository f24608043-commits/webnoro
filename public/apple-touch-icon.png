<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 180 180">
  <!-- Heart shape with N letter -->
  <defs>
    <linearGradient id="heartGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#22c55e;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#16a34a;stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- Heart background -->
  <path d="M90 160C75 150 40 120 40 75C40 45 65 20 95 20C110 20 125 30 135 45C145 30 160 20 175 20C205 20 230 45 230 75C230 120 195 150 180 160C165 170 145 180 120 180C110 180 100 170 90 160Z" fill="url(#heartGradient)"/>
  <!-- Letter N -->
  <text x="135" y="105" font-family="Arial, sans-serif" font-size="80" font-weight="bold" text-anchor="middle" fill="white">N</text>
</svg>
