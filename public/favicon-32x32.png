      <stop offset="0%" style="stop-color:#22c55e;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#16a34a;stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- Heart background -->
  <path d="M16 28.5C13.5 26.5 8 21 8 15C8 11 11 8 15 8C17 8 19 9 20 11C21 9 23 8 25 8C29 8 32 11 32 15C32 21 26.5 26.5 24 28.5C22 30.5 19 31.5 16 28.5Z" fill="url(#heartGradient)"/>
